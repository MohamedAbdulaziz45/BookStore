{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "BookStoreDb": "your-connection-string-here"
  },
  "Authentication": {
    "SecretKey": "your-secret-key-here",
    "Issuer": "bookstore-api",
    "Audience": "bookstore-api"
  },
  "Stripe": {
    "SecretKey": "your-stripe-secret-key-here",
    "WebhookSecret": "your-stripe-webhook-secret-here",
    "SuccessUrl": "your-success-url-here",
    "CancelUrl": "your-cancel-url-here"
  },
  "CloudinarySettings": {
    "CloudName": "your-actual-cloud-name",
    "ApiKey": "your-actual-api-key",
    "ApiSecret": "your-actual-api-secret"
  },
  "Serilog": {
    "MinimumLevel": {
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:dd-MM  HH:mm:ss} {Level:u3}] |{SourceContext}| {NewLine} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/BookStore-Api-.log",
          "rollingInterval": "Day",
          "fileSizeLimitBytes": 10485760,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter,Serilog.Formatting.Compact"
        }
      }
    ]
  }
}